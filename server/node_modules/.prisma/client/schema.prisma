generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// =========================
// USER
// =========================
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

// =========================
// CUSTOMER
// =========================
model Customer {
  id    Int     @id @default(autoincrement())
  name  String
  phone String?

  orders Order[]
}

// =========================
// PRODUCT
// =========================
model Product {
  id    Int    @id @default(autoincrement())
  name  String
  price Float
  stock Int

  items OrderItem[]
}

// =========================
// ORDER
// =========================
model Order {
  id        Int      @id @default(autoincrement())
  invoiceNo String?  @unique
  total     Float
  createdAt DateTime @default(now())

  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])

  items OrderItem[]
}

// =========================
// ORDER ITEM
// =========================
model OrderItem {
  id Int @id @default(autoincrement())

  orderId   Int
  productId Int?

  quantity Int
  price    Float

  order Order @relation(fields: [orderId], references: [id])

  product Product? @relation(fields: [productId], references: [id])
}

model Setting {
  id       Int     @id @default(autoincrement())
  shopName String
  address  String
  phone    String?
}
